{
  "version": "2.0",
  "optimized": "2026-05-22",
  "site": "topsarkarijobs.com",
  "targets": {
    "LCP": "< 2.5s",
    "CLS": "< 0.1",
    "INP": "< 200ms",
    "FCP": "< 1.8s",
    "TTFB": "< 600ms"
  },
  "features": {
    "serviceWorker": "sw.js v4",
    "criticalCSS": "critical.css v2",
    "perfUltra": "perf-ultra.js v2",
    "perfBoost": "perf-boost-v2.js",
    "lazyImages": true,
    "linkPrefetch": true,
    "networkAware": true,
    "lowMemoryMode": true,
    "passiveListeners": true
  }
}
