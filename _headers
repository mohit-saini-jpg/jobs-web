# ── AUDIT FIX: Data JSONs — Proper caching strategy ──────────────────
# BEFORE: All large JSONs were no-cache = 22MB+ re-downloaded every visit
# AFTER:  Smart TTLs — fresh enough for news site, cacheable for speed

# Complete Jobs (~22MB) — Only needed for full search. Cache 1 hour.
# stale-while-revalidate allows serving cached version while fetching new
# ISSUE-033 FIX: X-Robots-Tag so Googlebot doesn't index raw JSON
/Complete_Jobs_Full_Data.json
  Cache-Control: public, max-age=3600, stale-while-revalidate=7200
  Access-Control-Allow-Origin: *
  X-Robots-Tag: noindex, nofollow

# Daily updates — most time-sensitive. 5-min cache + 15-min stale.
/dailyupdates.json
  Cache-Control: public, max-age=300, stale-while-revalidate=900
  Access-Control-Allow-Origin: *

# Merged sarkari data (~843KB) — moderate freshness needed
/merged_sarkari_data.json
  Cache-Control: public, max-age=600, stale-while-revalidate=3600
  Access-Control-Allow-Origin: *

# State jobs data (~2.4MB) — changes less frequently, cache 30 min
/state-jobs-data.json
  Cache-Control: public, max-age=1800, stale-while-revalidate=86400
  Access-Control-Allow-Origin: *

# Sections index (~330KB) — lightweight index, cache 10 min
/sections-index.json
  Cache-Control: public, max-age=600, stale-while-revalidate=3600
  Access-Control-Allow-Origin: *

# Jobs index/search index — cache 30 min (changes less often)
/jobs-index.json
  Cache-Control: public, max-age=1800, stale-while-revalidate=86400
  Access-Control-Allow-Origin: *

/jobs-search-index.json
  Cache-Control: public, max-age=1800, stale-while-revalidate=86400
  Access-Control-Allow-Origin: *

